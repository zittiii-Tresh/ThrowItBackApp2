APP_NAME=SiteArchive
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Encrypt session data at rest. Cheap insurance if the sessions table
# is ever leaked (backup dump, dev clone, accidental export).
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: set to true so the session cookie is only sent over HTTPS.
# Leave null locally (Laravel auto-detects).
SESSION_SECURE_COOKIE=null
SESSION_HTTP_ONLY=true
# 'lax' blocks CSRF from cross-site POSTs while still letting normal
# top-level navigation carry the cookie.
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# SiteArchive renderer / crawler tunables
# -----------------------------------------------------------------------------
# Browsershot needs absolute paths to the Node + npm binaries used to spawn
# Puppeteer. On Windows + Laragon, the bundled Node lives here:
ARCHIVE_NODE_BINARY=C:/laragon/bin/nodejs/node-v22/node.exe
ARCHIVE_NPM_BINARY=C:/laragon/bin/nodejs/node-v22/npm.cmd
# Portable install (Start.bat) — uncomment + adjust to point at the bundled
# Node. Leave the Laragon paths above commented out:
# ARCHIVE_NODE_BINARY=./node/node.exe
# ARCHIVE_NPM_BINARY=./node/npm.cmd

# Renderer mode: 'browsershot' (default) uses real Chromium; 'static' captures
# the raw HTML the server returns (faster, misses JS-rendered content).
ARCHIVE_RENDERER=browsershot

# Crawler concurrency. Lower for fragile staging hosts that timeout under load.
ARCHIVE_CRAWL_CONCURRENCY=3

# Image-wait ceiling (ms). The renderer uses waitForFunction to capture only
# once every <img> has loaded or errored; this is the maximum wait. Per-site
# override available in Site Edit form.
ARCHIVE_RENDER_SETTLE_MS=20000
